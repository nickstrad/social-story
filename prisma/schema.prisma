generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id
  name              String
  email             String             @unique
  emailVerified     Boolean            @default(false)
  image             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  accounts          Account[]
  stories           Story[]
  tasks             Task[]
  assets            Asset[]
  libraryCharacters LibraryCharacter[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Story {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  script           String
  kind             StoryKind   @default(STORY)
  templateId       String?
  template         Story?      @relation("TemplateInstances", fields: [templateId], references: [id], onDelete: SetNull)
  instances        Story[]     @relation("TemplateInstances")
  status           StoryStatus @default(DRAFT)
  baseImageAssetId String?     @unique
  baseImageAsset   Asset?      @relation("StoryBaseImage", fields: [baseImageAssetId], references: [id], onDelete: SetNull)
  coverNote        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  characters       Character[]
  rules            Rule[]
  pages            Page[]
  tasks            Task[]
  assets           Asset[]     @relation("StoryAssets")

  @@unique([id, userId])
  @@index([userId, kind])
  @@index([userId, kind, createdAt, id])
  @@index([userId, kind, updatedAt, id])
  @@index([userId, kind, title, id])
}

model Character {
  id                 String            @id @default(cuid())
  storyId            String
  story              Story             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  name               String
  role               String?
  age                String?
  appearance         String?
  photoAssetId       String?           @unique
  photoAsset         Asset?            @relation("CharacterPhoto", fields: [photoAssetId], references: [id], onDelete: SetNull)
  photoDescription   String?
  libraryCharacterId String?
  libraryCharacter   LibraryCharacter? @relation(fields: [libraryCharacterId], references: [id], onDelete: SetNull)
  isOptional         Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([storyId])
}

model LibraryCharacter {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  role             String?
  age              String?
  appearance       String?
  photoAssetId     String?     @unique
  photoAsset       Asset?      @relation("LibraryCharacterPhoto", fields: [photoAssetId], references: [id], onDelete: SetNull)
  photoDescription String?
  storyCharacters  Character[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([userId])
  @@index([userId, createdAt, id])
  @@index([userId, name, id])
}

model Rule {
  id           String   @id @default(cuid())
  storyId      String
  story        Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  text         String
  kind         RuleKind
  characterIds String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storyId])
}

model Page {
  id              String      @id @default(cuid())
  storyId         String
  story           Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  kind            PageKind
  position        Int
  text            String
  imagePrompt     String
  characterIds    String[]
  steeringText    String?
  hidden          Boolean     @default(false)
  selectedImageId String?     @unique
  selectedImage   PageImage?  @relation("SelectedPageImage", fields: [selectedImageId], references: [id], onDelete: SetNull)
  images          PageImage[] @relation("PageImages")
  tasks           Task[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([storyId, position])
}

model PageImage {
  id           String          @id @default(cuid())
  pageId       String
  page         Page            @relation("PageImages", fields: [pageId], references: [id], onDelete: Cascade)
  selectedBy   Page?           @relation("SelectedPageImage")
  imageAssetId String          @unique
  imageAsset   Asset           @relation("PageImageCaptioned", fields: [imageAssetId], references: [id], onDelete: Restrict)
  rawAssetId   String?         @unique
  rawAsset     Asset?          @relation("PageImageRaw", fields: [rawAssetId], references: [id], onDelete: SetNull)
  source       PageImageSource @default(AI)
  promptUsed   String?
  variant      Int
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([pageId, variant])
}

model Asset {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId        String?
  story          Story?            @relation("StoryAssets", fields: [storyId, userId], references: [id, userId], onDelete: Cascade)
  kind           AssetKind
  storageLocator String            @unique
  contentType    String
  byteLength     Int
  filename       String?
  baseImageFor   Story?            @relation("StoryBaseImage")
  characterPhoto Character?        @relation("CharacterPhoto")
  libraryPhoto   LibraryCharacter? @relation("LibraryCharacterPhoto")
  captionedImage PageImage?        @relation("PageImageCaptioned")
  rawImage       PageImage?        @relation("PageImageRaw")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId, id])
  @@index([storyId])
}

model Task {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId    String
  story      Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  pageId     String?
  page       Page?      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type       TaskType
  status     TaskStatus @default(PENDING)
  error      String?
  resultJson Json?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([pageId])
  @@index([storyId, status])
}

enum StoryStatus {
  DRAFT
  PARSED
  READY
}

enum StoryKind {
  STORY
  TEMPLATE
}

enum RuleKind {
  TOGETHER
  ALWAYS_INCLUDE
  NEVER_INCLUDE
  FREEFORM
}

enum PageKind {
  COVER
  PAGE
}

enum PageImageSource {
  AI
  UPLOAD
}

enum TaskType {
  PARSE_STORY
  BASE_IMAGE
  PAGE_IMAGE
  PDF_EXPORT
}

enum TaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum AssetKind {
  BASE_IMAGE
  CHARACTER_PHOTO
  LIBRARY_PHOTO
  PAGE_IMAGE
  PAGE_IMAGE_RAW
  PDF
}
