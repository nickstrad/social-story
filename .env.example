DATABASE_URL="postgresql://user:password@host/database"
OPENAI_TOKEN=""
# Production: connect a private Blob store so Vercel supplies both values.
BLOB_STORE_ID=""
VERCEL_OIDC_TOKEN=""
# Local development fallback.
BLOB_READ_WRITE_TOKEN=""
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
OPENAI_CHAT_MODEL="gpt-5.5"
OPENAI_IMAGE_MODEL="gpt-image-2"

# Each product action can select its provider and model independently. The
# legacy OPENAI_*_MODEL values above remain the fallback when an action model
# is omitted.
AI_STORY_TO_DATA_PROVIDER="openai"
AI_STORY_TO_DATA_MODEL=""
AI_CHARACTER_PHOTO_AUTOFILL_PROVIDER="openai"
AI_CHARACTER_PHOTO_AUTOFILL_MODEL=""
AI_BASE_IMAGE_PROVIDER="openai"
AI_BASE_IMAGE_MODEL=""
AI_PAGE_IMAGE_PROVIDER="openai"
AI_PAGE_IMAGE_MODEL=""
AI_COVER_IMAGE_PROVIDER="openai"
AI_COVER_IMAGE_MODEL=""

# Local development uses the Inngest Dev Server and does not require real
# Inngest keys. `npm run dev` starts both local processes with mprocs.
INNGEST_DEV="1"

# Required in hosted environments where INNGEST_DEV is not enabled. Use the
# Event Key and Signing Key from the matching Inngest environment.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# Optional during signing-key rotation.
INNGEST_SIGNING_KEY_FALLBACK=""
