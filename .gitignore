# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.worktrees/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# local plan/judge workflow state
/CHANGE_SUMMARY.md
/HANDOFF.md
/JUDGEMENT.md

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client (generator output = ../src/generated/prisma)
/src/generated/prisma

# Backup of Go artifacts (pdfs, images, json)
/bkup/

# Go CLI runtime output (generated images, PDFs, personal photos)
/cli/images/
/cli/images_clean/
/cli/final_stories/
/cli/photos/
/cli/character_base.png
/cli/social-story
/cli/*.json
.env*.local
