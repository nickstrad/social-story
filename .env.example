DATABASE_URL="postgresql://user:password@host/database"
OPENAI_TOKEN=""
# Production: connect a private Blob store so Vercel supplies both values.
BLOB_STORE_ID=""
VERCEL_OIDC_TOKEN=""
# Local development fallback.
BLOB_READ_WRITE_TOKEN=""
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
OPENAI_CHAT_MODEL="gpt-5.5"
OPENAI_IMAGE_MODEL="gpt-image-2"

# Local development uses the Inngest Dev Server and does not require real
# Inngest keys. `npm run dev` starts both local processes with mprocs.
INNGEST_DEV="1"

# Required in hosted environments where INNGEST_DEV is not enabled. Use the
# Event Key and Signing Key from the matching Inngest environment.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# Optional during signing-key rotation.
INNGEST_SIGNING_KEY_FALLBACK=""
